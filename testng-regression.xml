<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MentorMatch Regression Suite" verbose="1" parallel="false" thread-count="6">
    <listeners>
        <listener class-name="com.mentormatch.automation.listeners.TestListener"/>
        <listener class-name="com.mentormatch.automation.listeners.RetryAnnotationTransformer"/>
    </listeners>
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.mentormatch.automation.tests.ReviewTests"/>
        </classes>
    </test>
</suite>
